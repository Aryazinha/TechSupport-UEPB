<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="650.0" prefWidth="1050.0" stylesheets="@style.css" styleClass="root" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.uepb.techsupport.controller.DashboardClienteController">

    <left>
        <VBox prefHeight="650.0" prefWidth="220.0" styleClass="sidebar" alignment="TOP_CENTER">
            <children>
                <Label fx:id="lblLogo" styleClass="logo-text" text="Client Portal">
                    <VBox.margin>
                        <Insets bottom="40.0" top="30.0" />
                    </VBox.margin>
                </Label>

                <Button fx:id="btnMeusChamados" mnemonicParsing="false" prefHeight="45.0" prefWidth="220.0" styleClass="menu-button-active" text="Meus Chamados" />
                <Button fx:id="btnNovoTicket" mnemonicParsing="false" onAction="#handleNovoChamado" prefHeight="45.0" prefWidth="220.0" styleClass="menu-button" text="Novo Ticket" />

                <Region VBox.vgrow="ALWAYS" />

                <Button mnemonicParsing="false" onAction="#handleLogout" prefHeight="45.0" prefWidth="250.0" styleClass="btn-logout" text="Sair">
                    <VBox.margin>
                        <Insets bottom="20.0" />
                    </VBox.margin>
                </Button>
            </children>
        </VBox>
    </left>

    <center>
        <VBox spacing="25.0" BorderPane.alignment="CENTER" style="-fx-padding: 30 35 30 35;">
            <children>
                <Label fx:id="lblBoasVindas" styleClass="titulo-pagina" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;" text="Dashboard do Cliente" />

                <HBox spacing="20.0">
                    <children>
                        <VBox alignment="CENTER" prefHeight="110.0" HBox.hgrow="ALWAYS" spacing="5.0">
                            <Label text="CHAMADOS ATIVOS" style="-fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-font-weight: bold; -fx-letter-spacing: 1px;"/>
                            <Label fx:id="lblAtivos" text="0" style="-fx-text-fill: #38bdf8; -fx-font-weight: bold; -fx-font-size: 38px;"/>
                        </VBox>

                        <VBox alignment="CENTER" prefHeight="110.0" HBox.hgrow="ALWAYS" spacing="5.0">
                            <Label text="RESOLVIDOS" style="-fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-font-weight: bold; -fx-letter-spacing: 1px;"/>
                            <Label fx:id="lblResolvidos" text="0" style="-fx-text-fill: #2ea043; -fx-font-weight: bold; -fx-font-size: 38px;"/>
                        </VBox>

                        <VBox alignment="CENTER" prefHeight="110.0" HBox.hgrow="ALWAYS" spacing="5.0">
                            <Label text="TOTAL DE TICKETS" style="-fx-text-fill: #94a3b8; -fx-font-size: 13px; -fx-font-weight: bold; -fx-letter-spacing: 1px;"/>
                            <Label fx:id="lblTotal" text="0" style="-fx-text-fill: #E2E8F0; -fx-font-weight: bold; -fx-font-size: 38px;"/>
                        </VBox>
                    </children>
                </HBox>

                <VBox VBox.vgrow="ALWAYS" style="-fx-padding: 0;">
                    <children>
                        <HBox alignment="CENTER_LEFT" style="-fx-padding: 15 15 5 15;">
                            <Label text="Meu Histórico de Tickets" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 18px;" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                        </HBox>

                        <TableView fx:id="tblChamados" VBox.vgrow="ALWAYS">
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                            <columns>
                                <TableColumn fx:id="colId" prefWidth="60.0" maxWidth="90.0" text="Ticket" styleClass="coluna-ticket" />
                                <TableColumn fx:id="colPrioridade" prefWidth="140.0" maxWidth="130.0" text="Prioridade"/>
                                <TableColumn fx:id="colDescricao" prefWidth="240.0" text="Descrição" styleClass="coluna-descricao" />
                                <TableColumn fx:id="colStatus" prefWidth="140.0" maxWidth="160.0" text="Status" style="-fx-alignment: CENTER;" />
                                <TableColumn fx:id="colData" prefWidth="140.0" maxWidth="160.0" text="Data de Abertura" styleClass="coluna-data" />
                            </columns>
                        </TableView>
                    </children>
                </VBox>
            </children>
        </VBox>
    </center>
</BorderPane>