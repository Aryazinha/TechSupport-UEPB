<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefWidth="700.0" spacing="25.0" styleClass="root" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.uepb.techsupport.controller.DetalhesChamadoController">

    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>

    <VBox spacing="5.0">
        <Label styleClass="titulo-pagina" text="Detalhes da Ordem de Serviço"/>
        <Label styleClass="subtitulo-pagina" text="Informações completas do chamado"/>
    </VBox>

    <GridPane hgap="30.0" vgap="20.0">
        <columnConstraints>
            <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" percentWidth="50.0" />
            <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" percentWidth="50.0" />
        </columnConstraints>
        <rowConstraints>
            <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
        </rowConstraints>
        <children>
            <VBox spacing="2.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                <Label styleClass="label-info-titulo" text="SOLICITANTE" />
                <Label fx:id="lblCliente" styleClass="label-info-valor" text="Carregando..." />
            </VBox>

            <VBox spacing="2.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                <Label styleClass="label-info-titulo" text="LOCALIZAÇÃO" />
                <Label fx:id="lblLocalizacao" styleClass="label-info-valor" text="..." />
            </VBox>

            <VBox spacing="2.0" GridPane.columnIndex="0" GridPane.rowIndex="1">
                <Label styleClass="label-info-titulo" text="CATEGORIA" />
                <Label fx:id="lblCategoria" styleClass="label-info-valor" text="..." wrapText="true" />
            </VBox>

            <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                <Label styleClass="label-info-titulo" text="STATUS E PRIORIDADE" />
                <HBox spacing="10.0" alignment="CENTER_LEFT">
                    <Label fx:id="lblStatus" text="..." />
                    <Label fx:id="lblPrioridade" text="..." />
                </HBox>
            </VBox>
        </children>
    </GridPane>

    <VBox spacing="5.0" VBox.vgrow="ALWAYS">
        <Label styleClass="label-info-titulo" text="DESCRIÇÃO DO PROBLEMA" />
        <TextArea fx:id="txtDescricao" editable="false" prefRowCount="6" styleClass="text-area-dark" wrapText="true" />
    </VBox>

    <VBox fx:id="boxSolucao" spacing="5.0" VBox.vgrow="ALWAYS">
        <Label styleClass="label-info-titulo" text="SOLUÇÃO APLICADA" />
        <TextArea fx:id="txtSolucao" editable="false" prefRowCount="4" styleClass="text-area-dark" wrapText="true" />
    </VBox>

    <HBox fx:id="boxValor" alignment="CENTER_RIGHT" spacing="10.0">
        <Label styleClass="label-info-titulo" text="VALOR TOTAL DO SERVIÇO:" />
        <Label fx:id="lblValor" styleClass="valor-total" text="R$ 0,00" />
    </HBox>

    <HBox alignment="CENTER_RIGHT" spacing="15.0">
        <VBox.margin>
            <Insets top="10.0" />
        </VBox.margin>
        <children>
            <Button mnemonicParsing="false" onAction="#handleVoltar" prefHeight="42.0" prefWidth="120.0" styleClass="btn-secondary" text="Voltar" />

            <Button fx:id="btnAssumir" mnemonicParsing="false" onAction="#handleAssumir" prefHeight="42.0" prefWidth="200.0" styleClass="btn-principal" text="Assumir este Chamado" />
        </children>
    </HBox>

</VBox>