<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="700.0" prefWidth="1150.0" spacing="25.0" styleClass="root" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.uepb.techsupport.controller.TicketsController">

    <padding>
        <Insets bottom="30.0" left="35.0" right="35.0" top="30.0" />
    </padding>

    <HBox alignment="CENTER_LEFT">
        <VBox spacing="5.0">
            <Label styleClass="titulo-pagina" text="Histórico de Tickets" />
            <Label styleClass="subtitulo-pagina" text="Consulte e gerencie todos os chamados realizados na UEPB." />
        </VBox>

        <Region HBox.hgrow="ALWAYS" />

        <Button onAction="#handleVoltar" prefHeight="42.0" prefWidth="180.0" styleClass="btn-secondary" text="Voltar ao Dashboard" />
    </HBox>

    <HBox alignment="CENTER_LEFT" spacing="15.0" styleClass="card-estatistica" style="-fx-padding: 15;">
        <TextField fx:id="txtPesquisa" prefHeight="40.0" prefWidth="350.0" promptText="🔍 Buscar cliente, local ou problema..." styleClass="text-field-dark" />

        <Region HBox.hgrow="ALWAYS" />

        <ComboBox fx:id="cbFiltroStatus" prefHeight="40.0" prefWidth="160.0" promptText="Status" styleClass="combo-box-dark" />
        <ComboBox fx:id="cbFiltroPrioridade" prefHeight="40.0" prefWidth="160.0" promptText="Prioridade" styleClass="combo-box-dark" />

        <Button onAction="#handleLimparFiltros" prefHeight="40.0" prefWidth="100.0" styleClass="btn-secondary" text="Limpar" />
    </HBox>

    <VBox styleClass="card-estatistica" VBox.vgrow="ALWAYS" style="-fx-padding: 0;">
        <TableView fx:id="tblHistorico" VBox.vgrow="ALWAYS" prefHeight="450.0">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
            <columns>
                <TableColumn fx:id="colId" prefWidth="60.0" text="Ticket" styleClass="coluna-ticket" />
                <TableColumn fx:id="colCliente" prefWidth="160.0" text="Cliente" styleClass="coluna-cliente"/>
                <TableColumn fx:id="colCategoria" prefWidth="150.0" text="Categoria" styleClass="coluna-categoria"/>
                <TableColumn fx:id="colPrioridade" prefWidth="110.0" text="Prioridade"/>
                <TableColumn fx:id="colDescricao" prefWidth="240.0" text="Descrição" styleClass="coluna-descricao"/>
                <TableColumn fx:id="colStatus" prefWidth="120.0" text="Status" />
                <TableColumn fx:id="colData" prefWidth="140.0" text="Data" styleClass="coluna-data" />
            </columns>
        </TableView>
    </VBox>

</VBox>