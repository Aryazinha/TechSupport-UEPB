<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" prefHeight="550.0" prefWidth="500.0" spacing="25.0" styleClass="root" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.uepb.techsupport.controller.LoginController">

    <padding>
        <Insets bottom="30.0" left="40.0" right="40.0" top="20.0" />
    </padding>

    <VBox maxWidth="400.0" spacing="20.0">
        <VBox alignment="CENTER" spacing="5.0">
            <Label styleClass="login-titulo" text="TechSupport" />
            <Label styleClass="login-subtitulo" text="UEPB" />
        </VBox>

        <VBox spacing="20.0" styleClass="card-formulario">

            <VBox spacing="8.0">
                <Label styleClass="form-label" text="ENDEREÇO DE E-MAIL" />
                <TextField fx:id="txtEmail" prefHeight="42.0" promptText="exemplo@uepb.edu.br" styleClass="input-auth" />
            </VBox>

            <VBox spacing="8.0">
                <HBox alignment="CENTER_LEFT">
                    <Label styleClass="form-label" text="SENHA" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label styleClass="label-destaque" text="RESTRITO" />
                </HBox>
                <PasswordField fx:id="txtSenha" prefHeight="42.0" promptText="••••••••" styleClass="input-auth" />
            </VBox>

            <Button fx:id="btnEntrar" defaultButton="true" maxWidth="Infinity" onAction="#handleLogin" prefHeight="45.0" styleClass="btn-principal" text="Entrar" />
        </VBox>

        <HBox alignment="CENTER" spacing="5.0" styleClass="auth-footer">
            <Label styleClass="texto-secundario" text="Novo no sistema?" />
            <Hyperlink onAction="#abrirTelaCadastro" styleClass="link-auth" text="Crie uma conta." />
        </HBox>
    </VBox>
</VBox>